<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Dark theme -->
    <style name="Theme.DIRASSAFeeRecord" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/primary_light</item>
        <item name="colorPrimaryVariant">@color/primary</item>
        <item name="colorOnPrimary">@color/dark_background</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/dark_background</item>
        <item name="colorSurface">@color/dark_surface</item>
        <item name="colorOnSurface">@color/dark_on_surface</item>
        <item name="android:colorBackground">@color/dark_background</item>
        <item name="android:statusBarColor">@color/dark_surface</item>
        <item name="android:navigationBarColor">@color/dark_background</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>

    <style name="Theme.DIRASSAFeeRecord.Splash" parent="Theme.DIRASSAFeeRecord">
        <item name="android:statusBarColor">@color/dark_surface</item>
    </style>
</resources>
