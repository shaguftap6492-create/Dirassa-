<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        style="@style/Widget.DIRASSAFeeRecord.Toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize" />

    <!-- Loading indicator -->
    <ProgressBar
        android:id="@+id/pbLoading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Section: Data -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DATA MANAGEMENT"
                android:textColor="@color/primary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginStart="8dp"
                android:layout_marginBottom="4dp" />

            <!-- Backup -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/layoutBackup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="💾" android:textSize="24sp" android:layout_marginEnd="12dp" />

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Backup Database" android:textSize="15sp" android:textStyle="bold" />

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Save database to share or store" android:textSize="12sp"
                            android:textColor="@color/hint_text" />
                    </LinearLayout>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="›" android:textSize="22sp" android:textColor="@color/hint_text" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Restore -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/layoutRestore"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:padding="16dp" android:gravity="center_vertical">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="📂" android:textSize="24sp" android:layout_marginEnd="12dp" />

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Restore Database" android:textSize="15sp" android:textStyle="bold" />

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Restore from backup file" android:textSize="12sp"
                            android:textColor="@color/hint_text" />
                    </LinearLayout>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="›" android:textSize="22sp" android:textColor="@color/hint_text" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Export Excel -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/layoutExportExcel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:padding="16dp" android:gravity="center_vertical">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="📊" android:textSize="24sp" android:layout_marginEnd="12dp" />

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Export to Excel" android:textSize="15sp" android:textStyle="bold" />

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Export all records as .xlsx" android:textSize="12sp"
                            android:textColor="@color/hint_text" />
                    </LinearLayout>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="›" android:textSize="22sp" android:textColor="@color/hint_text" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Export PDF -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/layoutExportPdf"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:padding="16dp" android:gravity="center_vertical">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="📄" android:textSize="24sp" android:layout_marginEnd="12dp" />

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Export to PDF" android:textSize="15sp" android:textStyle="bold" />

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Export complete report as PDF" android:textSize="12sp"
                            android:textColor="@color/hint_text" />
                    </LinearLayout>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="›" android:textSize="22sp" android:textColor="@color/hint_text" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Reset -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/layoutReset"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp"
                app:strokeColor="@color/pending_red"
                app:strokeWidth="1dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:padding="16dp" android:gravity="center_vertical">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🗑" android:textSize="24sp" android:layout_marginEnd="12dp" />

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Reset All Data" android:textSize="15sp" android:textStyle="bold"
                            android:textColor="@color/pending_red" />

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Delete all students and records" android:textSize="12sp"
                            android:textColor="@color/hint_text" />
                    </LinearLayout>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="›" android:textSize="22sp" android:textColor="@color/pending_red" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Section: Appearance -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="APPEARANCE"
                android:textColor="@color/primary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginStart="8dp"
                android:layout_marginBottom="4dp" />

            <!-- Dark Mode -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:padding="16dp" android:gravity="center_vertical">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🌙" android:textSize="24sp" android:layout_marginEnd="12dp" />

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Dark Mode" android:textSize="15sp" android:textStyle="bold" />

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Switch to dark theme" android:textSize="12sp"
                            android:textColor="@color/hint_text" />
                    </LinearLayout>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchDarkMode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Section: About -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="APP"
                android:textColor="@color/primary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginStart="8dp"
                android:layout_marginBottom="4dp" />

            <!-- About -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/layoutAbout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:padding="16dp" android:gravity="center_vertical">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="ℹ" android:textSize="24sp" android:layout_marginEnd="12dp" />

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="About DIRASSA CLASSES" android:textSize="15sp" android:textStyle="bold" />

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Version 1.0.0" android:textSize="12sp"
                            android:textColor="@color/hint_text" />
                    </LinearLayout>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="›" android:textSize="22sp" android:textColor="@color/hint_text" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
