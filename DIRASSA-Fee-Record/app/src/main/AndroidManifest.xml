<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Permissions for file export and sharing -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29" />

    <application
        android:name=".FeeRecordApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.DIRASSAFeeRecord">

        <!-- Splash / Home Screen -->
        <activity
            android:name=".ui.splash.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.DIRASSAFeeRecord.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Main Home Screen -->
        <activity
            android:name=".ui.home.HomeActivity"
            android:exported="false" />

        <!-- Add / Edit Student Screen -->
        <activity
            android:name=".ui.student.AddEditStudentActivity"
            android:exported="false"
            android:windowSoftInputMode="stateVisible|adjustResize" />

        <!-- Student List Screen -->
        <activity
            android:name=".ui.student.StudentListActivity"
            android:exported="false" />

        <!-- Fee Record Screen -->
        <activity
            android:name=".ui.fee.FeeRecordActivity"
            android:exported="false"
            android:windowSoftInputMode="stateVisible|adjustResize" />

        <!-- Monthly Report Screen -->
        <activity
            android:name=".ui.report.MonthlyReportActivity"
            android:exported="false" />

        <!-- Settings Screen -->
        <activity
            android:name=".ui.settings.SettingsActivity"
            android:exported="false" />

        <!-- FileProvider for sharing PDFs -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.provider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
